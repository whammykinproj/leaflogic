# ============================================
# JobScout AI — Environment Variables
# ============================================
# Copy to .env.local and fill in values

# Supabase (create project at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (create account at stripe.com)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_SCOUT_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (create account at resend.com)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=JobScout AI <hello@yourdomain.com>

# Anthropic (for AI job analysis)
ANTHROPIC_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Vercel Cron (auto-set by Vercel, or set manually for testing)
CRON_SECRET=your-cron-secret

# Admin dashboard (access at /scout/admin?token=YOUR_TOKEN)
SCOUT_ADMIN_TOKEN=your-secret-admin-token

# ============================================
# Existing LeafLogic vars (keep these)
# ============================================
# NEXT_PUBLIC_ADSENSE_ID=
# JOB_SCOUT_TEST_TOKEN=
